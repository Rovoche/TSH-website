---
import BaseLayout from '../layouts/BaseLayout.astro';

const values = [
  {
    name: 'Selflessness',
    copy: 'We lead with care, helping without making it about ourselves. Your need always comes first in this space.',
    border: 'border-flag-blue',
  },
  {
    name: 'Love',
    copy: "We believe in love's power to heal, connect, and uplift. Every interaction in our community is rooted in genuine kindness.",
    border: 'border-flag-red',
  },
  {
    name: 'Sensitivity',
    copy: 'We respond gently, honoring what someone is carrying. Tact and care always come before speed in how we engage.',
    border: 'border-flag-green',
  },
];

const stats = [
  { value: '11', suffix: '', label: 'Years of Community', bar: 'bg-flag-blue' },
  { value: '10000', suffix: '+', label: 'Young People Reached', bar: 'bg-flag-red' },
  { value: '10', suffix: '+', label: 'Nigerian States', bar: 'bg-flag-green' },
  { value: '20', suffix: '+', label: 'Offline Meetups', bar: 'bg-flag-blue' },
  { value: '50', suffix: '+', label: 'Online Programs', bar: 'bg-flag-red' },
];

const testimonials = [
  {
    name: 'Goodnews Ifot',
    quote:
      'TSH is not just a community, it is home. It was there for me during some of my hardest moments, reminding me that I was not alone.',
    image: '/images/Testimonials/Testimonials-Goodnews-Ifot (2).jpg',
    ring: 'ring-flag-blue',
  },
  {
    name: 'Ejiro Edwards',
    quote:
      'I came in struggling with low self-esteem and depression, but the love here helped rebuild my confidence.',
    image: '/images/Testimonials/Testimonials-Ejiro-Edwards (6).jpg',
    ring: 'ring-flag-red',
  },
  {
    name: 'Darlington Nze',
    quote:
      'Since joining, I have met brilliant minds, discovered amazing talents, and learned to believe in myself again.',
    image: '/images/Testimonials/Testimonials-Darlington-Nze (1).jpg',
    ring: 'ring-flag-green',
  },
  {
    name: 'Grace Mfon',
    quote:
      'Whether online or offline, this community feels like family. A judgment-free home where I have grown in ways I never imagined.',
    image: '/images/Testimonials/Testimonials-Grace-Mfon (3).jpg',
    ring: 'ring-flag-blue',
  },
];
---

<BaseLayout
  title="Twayne Safe Haven | Youth Mental Health & Wellbeing Community in Nigeria"
  description="Twayne Safe Haven is a youth mental health and wellbeing community built on storytelling, peer connection, and emotional support for young Nigerians."
>
  <!-- HERO — true full-bleed, dark gradient overlay, subtle parallax -->
  <section class="relative h-[86vh] min-h-[560px] w-full overflow-hidden">
    <img
      id="hero-image"
      src="/images/Homepage/TSH-Hero.jpg"
      alt="Six members of the Twayne Safe Haven community lying in a circle on the grass, heads together, laughing."
      class="absolute inset-0 h-[112%] w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-deep via-navy-deep/35 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-deep/50 via-transparent to-transparent"></div>

    <div class="relative z-10 mx-auto flex h-full max-w-wide flex-col justify-end px-6 pb-16 lg:px-10 lg:pb-24">
      <p class="text-xs uppercase tracking-[0.2em] text-flag-red">Stories. Support. Community.</p>
      <h1 class="mt-5 max-w-2xl font-display text-[2.75rem] leading-[1.05] tracking-tightest text-paper sm:text-[4.25rem]">
        Where Every Story <em class="font-normal italic text-flag-green" data-hero-emphasis>Creates Magic</em>
      </h1>
      <p class="prose-copy mt-6 max-w-lg text-paper/85">
        Magic begins the moment we feel safe enough to be seen. Twayne Safe Haven is a peer
        storytelling community that supports the mental health and wellbeing of young Nigerians.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/join-the-community" class="btn-primary !bg-paper !text-ink hover:!bg-flag-blue hover:!text-paper">
          Join the Community
        </a>
        <a href="/our-approach" class="btn-secondary !border-paper/40 !text-paper hover:!bg-paper hover:!text-ink">
          Learn More
        </a>
      </div>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="mx-auto max-w-wide px-6 py-20 text-center lg:py-28" data-reveal>
    <p class="text-xs uppercase tracking-[0.16em] text-flag-blue">Who We Are</p>
    <h2 class="mx-auto mt-4 max-w-2xl font-display text-3xl leading-[1.15] sm:text-4xl">
      A youth-led community built on
      <em class="italic text-flag-green">stories, support, and belonging.</em>
    </h2>
    <p class="prose-copy mx-auto mt-6 max-w-xl">
      Founded in 2015, Twayne Safe Haven creates spaces where young Nigerians can share their
      stories, feel seen, build real connection, and support their wellbeing together.
    </p>
  </section>

  <!-- Full-bleed breakout photo — the page's first "breathing" moment -->
  <section class="bleed relative h-[52vh] min-h-[340px] max-h-[560px] overflow-hidden" data-reveal>
    <img
      src="/images/Our-Approach/imgi_1_IMG-20241229-WA0046.jpg"
      alt="A group of Twayne Safe Haven members gathered outdoors, laughing together after a community meetup."
      class="h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-deep/70 via-transparent to-transparent"></div>
    <p class="absolute bottom-6 left-6 font-display text-lg italic text-paper/90 sm:bottom-8 sm:left-10 sm:text-xl">
      Storytelling Support Belonging
    </p>
  </section>

  <!-- Mission & Vision -->
  <section class="mx-auto max-w-wide px-6 py-20 lg:px-10 lg:py-28">
    <div data-reveal>
      <p class="text-xs uppercase tracking-[0.16em] text-flag-blue">Mission and Vision</p>
      <h2 class="mt-4 max-w-2xl font-display text-3xl leading-[1.15] sm:text-4xl">
        Built on purpose. <em class="italic text-flag-green">Driven by people.</em>
      </h2>
      <p class="prose-copy mt-5 max-w-2xl">
        We create safe spaces for young Nigerians to share their stories, build real connection,
        and support their wellbeing together.
      </p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2">
      <div class="rounded-lg border-t-[3px] border-flag-blue bg-paper-dim p-8 transition-transform duration-300 hover:-translate-y-1" data-reveal>
        <p class="text-xs uppercase tracking-[0.14em] text-flag-blue">Mission</p>
        <p class="mt-3 font-display text-xl leading-snug">
          Improve young people's mental and emotional wellbeing by building safe, inclusive
          spaces for storytelling and support.
        </p>
      </div>
      <div class="rounded-lg border-t-[3px] border-flag-green bg-paper-dim p-8 transition-transform duration-300 hover:-translate-y-1" data-reveal>
        <p class="text-xs uppercase tracking-[0.14em] text-flag-green">Vision</p>
        <p class="mt-3 font-display text-xl leading-snug">
          A generation of young people across Nigeria and beyond who are heard, deeply connected,
          and thriving.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Do — navy, not green; small colored marks instead of a full wash -->
  <section class="bg-navy text-paper">
    <div class="mx-auto max-w-wide px-6 py-20 lg:px-10 lg:py-28">
      <div data-reveal>
        <p class="text-xs uppercase tracking-[0.16em] text-flag-red">What We Do</p>
        <h2 class="mt-4 max-w-2xl font-display text-3xl leading-[1.15] sm:text-4xl">
          Three ways we <em class="italic text-flag-green">show up.</em>
        </h2>
        <p class="mt-5 max-w-xl text-paper/70">
          Everything we do creates conditions for young people to be heard, connected, and
          supported. Simple, human, and real.
        </p>
      </div>

      <div class="mt-14 divide-y divide-paper/10 border-t border-paper/10">
        <div class="grid gap-3 py-10 sm:grid-cols-[10rem_1fr] sm:gap-8" data-reveal>
          <h3 class="flex items-center gap-3 font-display text-2xl text-paper">
            <span class="h-2 w-2 rounded-full bg-flag-blue"></span>Storytelling
          </h3>
          <p class="max-w-2xl text-paper/75">
            We create spaces where young people can speak what they have been carrying. The act
            of sharing and being witnessed is the first step toward healing. Every story told
            here matters.
          </p>
        </div>
        <div class="grid gap-3 py-10 sm:grid-cols-[10rem_1fr] sm:gap-8" data-reveal>
          <h3 class="flex items-center gap-3 font-display text-2xl text-paper">
            <span class="h-2 w-2 rounded-full bg-flag-red"></span>Connection
          </h3>
          <p class="max-w-2xl text-paper/75">
            We build belonging that crosses states, screens, and backgrounds. Our community
            brings people together through shared experiences so that no one ever has to face
            their story alone.
          </p>
        </div>
        <div class="grid gap-3 py-10 sm:grid-cols-[10rem_1fr] sm:gap-8" data-reveal>
          <h3 class="flex items-center gap-3 font-display text-2xl text-paper">
            <span class="h-2 w-2 rounded-full bg-flag-green"></span>Growth
          </h3>
          <p class="max-w-2xl text-paper/75">
            We create conditions for confidence, reflection, and becoming. Through programs,
            peer support, and community, we help young people discover who they are and what
            they are capable of.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact stats — count up on scroll, flag color rotation -->
  <section class="mx-auto max-w-wide px-6 py-20 lg:px-10 lg:py-28" data-reveal>
    <p class="text-xs uppercase tracking-[0.16em] text-flag-blue">Our Impact</p>
    <h2 class="mt-4 max-w-xl font-display text-3xl leading-[1.15] sm:text-4xl">
      Eleven years of <em class="italic text-flag-green">showing up.</em>
    </h2>
    <dl class="mt-12 grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-5">
      {stats.map((stat) => (
        <div>
          <dt class="sr-only">{stat.label}</dt>
          <span class={`mb-2 block h-1 w-8 rounded-full ${stat.bar}`}></span>
          <dd class="font-display text-4xl text-ink sm:text-5xl" data-count-to={`${stat.value}${stat.suffix}`}>
            0
          </dd>
          <p class="mt-2 text-sm text-ink-soft">{stat.label}</p>
        </div>
      ))}
    </dl>
  </section>

  <!-- Who is a Twayne — bigger, sharper image, no more "sticker" framing -->
  <section class="border-t border-ink/10 bg-paper-dim">
    <div class="mx-auto grid max-w-wide items-stretch lg:grid-cols-2">
      <img
        src="/images/Homepage/Who-is-a-twayne.jpg"
        alt="A member of the Twayne Safe Haven community"
        class="h-[340px] w-full object-cover lg:h-full"
        loading="lazy"
        data-reveal
      />
      <div class="flex flex-col justify-center px-6 py-16 lg:px-16 lg:py-0" data-reveal>
        <p class="text-xs uppercase tracking-[0.16em] text-flag-red">Community Identity</p>
        <h2 class="mt-4 font-display text-3xl leading-[1.15] sm:text-4xl">
          Who Is <em class="italic text-flag-green">A Twayne?</em>
        </h2>
        <p class="prose-copy mt-6">
          A Twayne is not just a member. It is a mindset. It is choosing warmth over silence,
          courage over hiding, and community over isolation.
        </p>
        <p class="prose-copy mt-4">
          Whether you are sharing your truth for the first time or holding space for someone
          else through theirs, this is your safe haven.
        </p>
        <a href="/join-the-community" class="btn-primary mt-8 w-fit">Become a Twayne</a>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="mx-auto max-w-wide px-6 py-20 lg:px-10 lg:py-28">
    <div data-reveal>
      <p class="text-xs uppercase tracking-[0.16em] text-flag-blue">Our Values</p>
      <h2 class="mt-4 max-w-xl font-display text-3xl leading-[1.15] sm:text-4xl">
        The values that shape <em class="italic text-flag-green">how we show up.</em>
      </h2>
    </div>
    <div class="mt-12 grid gap-10 sm:grid-cols-3">
      {values.map((value) => (
        <div class={`border-t-[3px] ${value.border} pt-6 transition-transform duration-300 hover:-translate-y-1`} data-reveal>
          <h3 class="font-display text-xl">{value.name}</h3>
          <p class="mt-3 text-[0.95rem] leading-relaxed text-ink-soft">{value.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Testimonials — navy, hover-lift cards -->
  <section class="bg-navy text-paper">
    <div class="mx-auto max-w-wide px-6 py-20 lg:px-10 lg:py-28">
      <div data-reveal>
        <p class="text-xs uppercase tracking-[0.16em] text-flag-red">Stories from Our Community</p>
        <h2 class="mt-4 max-w-xl font-display text-3xl leading-[1.15] text-paper sm:text-4xl">
          Real people. <em class="italic text-flag-green">Real stories.</em>
        </h2>
      </div>

      <div class="mt-12 flex snap-x gap-6 overflow-x-auto pb-4 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {testimonials.map((t) => (
          <figure class="w-[280px] shrink-0 snap-start rounded-lg bg-navy-mid p-6 transition-transform duration-300 hover:-translate-y-1.5 sm:w-[320px]" data-reveal>
            <img
              src={t.image}
              alt={`Portrait of ${t.name}, a Twayne Safe Haven member`}
              class={`h-14 w-14 rounded-full object-cover ring-2 ${t.ring}`}
              loading="lazy"
            />
            <blockquote class="mt-5 text-[0.95rem] leading-relaxed text-paper/90">
              "{t.quote}"
            </blockquote>
            <figcaption class="mt-4 text-sm font-medium text-paper/70">{t.name}</figcaption>
          </figure>
        ))}
      </div>
      <p class="mt-2 text-xs text-paper/40">Swipe to read more stories</p>
    </div>
  </section>

  <!-- Invitation — full-bleed photographic close, bookends the hero -->
  <section class="bleed relative overflow-hidden py-28 text-center lg:py-36">
    <img
      src="/images/About-us/closing.jpg"
      alt="Twayne Safe Haven community members together"
      class="absolute inset-0 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-navy-deep/80"></div>
    <div class="relative z-10 mx-auto max-w-2xl px-6" data-reveal>
      <p class="text-xs uppercase tracking-[0.16em] text-flag-red">An Invitation</p>
      <h2 class="mt-4 font-display text-3xl leading-[1.15] text-paper sm:text-4xl">
        Come as you are. <em class="italic text-flag-green">We will make space.</em>
      </h2>
      <p class="prose-copy mx-auto mt-5 max-w-xl text-paper/80">
        If you have been looking for a place to feel seen, supported, and understood, this is
        it. Your voice matters here, even if you are still finding it.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/join-the-community" class="btn-primary !bg-paper !text-ink hover:!bg-flag-blue hover:!text-paper">
          Join the Community
        </a>
        <a href="/about" class="btn-secondary !border-paper/40 !text-paper hover:!bg-paper hover:!text-ink">
          Explore Our Story
        </a>
      </div>
      <p class="mt-6 text-sm text-paper/60">Free to join. Safe to be. Always welcome.</p>
    </div>
  </section>
</BaseLayout>

<script>
  // Signature hero moment: the italicized word opens up on load.
  const emphasis = document.querySelector('[data-hero-emphasis]');
  if (emphasis && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    emphasis.animate(
      [
        { letterSpacing: '-0.01em', opacity: 0.75 },
        { letterSpacing: '0.005em', opacity: 1 },
      ],
      { duration: 1400, easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fill: 'forwards' }
    );
  }

  // Subtle hero parallax — the image drifts slower than the scroll.
  const heroImage = document.getElementById('hero-image');
  if (heroImage && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const offset = Math.min(window.scrollY * 0.15, 90);
          heroImage.style.transform = `translateY(${offset}px)`;
          ticking = false;
        });
      },
      { passive: true }
    );
  }
</script>
