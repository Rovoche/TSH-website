---
import fs from 'node:fs';
import path from 'node:path';

// Inline the real TSH crest SVG so the flag paths (blue/green/red) can be
// targeted directly by CSS and given a gentle waving motion. This is the
// one signature motion moment on the site — everything else stays still.
const logoPath = path.resolve('./public/images/Logo-Icons/TSH-Icon.svg');
const logoSvg = fs.readFileSync(logoPath, 'utf-8');

const links = [
  { href: '/about', label: 'About Us' },
  { href: '/our-approach', label: 'Our Approach' },
  { href: '/join-the-community', label: 'Join The Community' },
  { href: '/gallery', label: 'Our Gallery' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="sticky top-0 z-40 border-b border-ink/10 bg-paper/90 backdrop-blur">
  <div class="mx-auto flex max-w-wide items-center justify-between px-6 py-4 lg:px-10">
    <a href="/" class="flex items-center gap-3" aria-label="Twayne Safe Haven — home">
      <span class="tsh-crest h-10 w-auto" set:html={logoSvg} />
      <span class="font-display text-lg leading-tight text-ink">
        Twayne<br /><span class="font-semibold">Safe Haven</span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-8 lg:flex">
      {links.map((link) => (
        
          href={link.href}
          class="text-[0.95rem] text-ink-soft transition-colors hover:text-ember-600"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      
        href="https://twaynesafehaven.betterworld.org/campaigns/twayne-safe-haven-inaugural-crow"
        class="btn-primary hidden sm:inline-flex"
      >
        Donate
      </a>
      <button
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-full border border-ink/20 p-2.5 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M2 5h16M2 10h16M2 15h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    aria-label="Mobile"
    class="hidden flex-col gap-1 border-t border-ink/10 bg-paper px-6 pb-6 pt-2 lg:hidden"
  >
    {links.map((link) => (
      <a href={link.href} class="rounded-lg px-2 py-3 text-ink-soft hover:bg-ink/5">
        {link.label}
      </a>
    ))}
    
      href="https://twaynesafehaven.betterworld.org/campaigns/twayne-safe-haven-inaugural-crow"
      class="btn-primary mt-2 justify-center"
    >
      Donate
    </a>
  </nav>
</header>

<style>
  .tsh-crest :global(svg) {
    height: 100%;
    width: auto;
    overflow: visible;
  }

  /* The three flag-wave paths in the source SVG use these exact fills. */
  .tsh-crest :global(path[fill='#3A6EA5']),
  .tsh-crest :global(path[fill='#5AAD80']),
  .tsh-crest :global(path[fill='#E05555']) {
    transform-box: fill-box;
    transform-origin: 0% 50%;
    animation: tsh-wave 3.6s ease-in-out infinite;
  }
  .tsh-crest :global(path[fill='#5AAD80']) {
    animation-delay: 0.12s;
  }
  .tsh-crest :global(path[fill='#E05555']) {
    animation-delay: 0.22s;
  }

  @keyframes tsh-wave {
    0%, 100% { transform: skewY(0deg) scaleY(1); }
    50% { transform: skewY(-3.5deg) scaleY(1.015); }
  }

  @media (prefers-reduced-motion: reduce) {
    .tsh-crest :global(path) {
      animation: none !important;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('flex');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!!isOpen));
  });
</script>
